# ============================================
# MindMap AI - 后端环境变量配置
# ============================================
#
# 使用方法:
# 1. 复制本文件为 .env:  cp .env.example .env
# 2. 填入你的配置值（去掉 <> 括号）
# 3. 运行: uvicorn app.main:app --reload
#
# ⚠️ 重要安全提示:
# - .env 文件包含敏感信息，请勿提交到 Git！
# - 已添加到 .gitignore
# ============================================

# --------------------------------------------
# 基础配置（可选，有默认值）
# --------------------------------------------

# 运行环境
# 可选值: development | production
# 默认值: development
ENV=development

# 应用名称
# 默认值: mindmap-backend
APP_NAME=mindmap-backend

# 跨域允许来源（CORS）
# 开发环境: http://localhost:8081,http://localhost:19006
# 生产环境: https://your-frontend-domain.com
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# --------------------------------------------
# Supabase 数据库配置（✅ 必填）
# 获取方式: https://supabase.com/dashboard > 你的项目 > Settings > API
# --------------------------------------------

# Supabase 项目 URL
# 示例: https://abcdefgh12345678.supabase.co
SUPABASE_URL=<your_supabase_project_url>

# Supabase 匿名密钥（Anon Key）
# 用于验证用户 JWT
SUPABASE_ANON_KEY=<your_supabase_anon_key>

# Supabase 服务角色密钥（Service Role Key）
# ⚠️ 警告: 此密钥具有最高权限，切勿泄露给前端！
# 仅用于后端服务器操作
SUPABASE_SERVICE_ROLE_KEY=<your_supabase_service_role_key>

# --------------------------------------------
# 加密配置（✅ 必填）
# 用于加密用户存储的 AI API Keys
# --------------------------------------------

# Fernet 加密密钥
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 输出示例: gAAAAABl...
# ⚠️ 重要: 妥善保存此密钥，丢失后无法解密已存储的 API Keys！
APP_ENCRYPTION_KEY=<generate_fernet_key>

# --------------------------------------------
# AI 模型配置（可选，有默认值）
# --------------------------------------------

# DeepSeek API 基础 URL
# 默认值: https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称
# 可选值: deepseek-chat | deepseek-coder
# 默认值: deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# --------------------------------------------
# Celery / Redis 配置（可选，开发模式可空）
# --------------------------------------------

# Redis URL（用于 Celery 任务队列）
# 格式: redis://[:password@]host:port/db
# 本地开发: redis://localhost:6379/0
# 如果使用 Render: 会自动注入，此处可留空
REDIS_URL=

# Celery Broker URL（消息队列）
# 默认使用 REDIS_URL 或 localhost
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery 结果后端（任务结果存储）
# 默认使用 REDIS_URL 或 localhost
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --------------------------------------------
# 文件上传配置（可选，有默认值）
# --------------------------------------------

# 最大上传文件大小（字节）
# 默认值: 10485760 (10MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# 本地思维导图输出目录
# 默认值: local_output/mindmaps
LOCAL_MINDMAP_OUTPUT_DIR=local_output/mindmaps

# --------------------------------------------
# 任务轮询配置（可选，有默认值）
# --------------------------------------------

# Job 状态轮询间隔（秒）
# 默认值: 2
JOB_POLL_INTERVAL_SECONDS=2
