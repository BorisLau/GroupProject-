# ============================================
# MindMap AI - 前端环境变量配置
# ============================================
# 
# 使用方法:
# 1. 复制本文件为 .env:  cp .env.example .env
# 2. 填入你的配置值（去掉 <> 括号）
# 3. 重启应用生效
#
# 快速开始: 开发模式下，这些变量有默认值可直接运行
# ============================================

# --------------------------------------------
# Supabase 数据库配置（必填）
# 获取方式: https://supabase.com/dashboard > 你的项目 > Settings > API
# --------------------------------------------

# Supabase 项目 URL
# 示例: https://abcdefgh12345678.supabase.co
EXPO_PUBLIC_SUPABASE_URL=<your_supabase_project_url>

# Supabase 匿名密钥（Anon Key）
# 注意: 使用 anon key，不是 service_role key
# 示例: eyJhbGciOiJIUzI1NiIs...
EXPO_PUBLIC_SUPABASE_KEY=<your_supabase_anon_key>

# --------------------------------------------
# 后端 API 配置（可选，开发模式有默认值）
# --------------------------------------------

# 后端 API 基础 URL
# 默认值: http://localhost:8000
# 本地开发: http://localhost:8000
# 生产环境: https://your-backend-domain.com
EXPO_PUBLIC_BACKEND_URL=http://localhost:8000

# 备选后端 URL（优先级低于 BACKEND_URL）
# EXPO_PUBLIC_BACKEND_BASE_URL=

# --------------------------------------------
# 开发/生产环境标识（可选）
# --------------------------------------------

# 环境模式
# 可选值: development | production
# 默认值: development
EXPO_PUBLIC_ENV=development

# 调试模式
# 可选值: true | false
# 默认值: true（开发）/ false（生产）
EXPO_PUBLIC_DEBUG=true
